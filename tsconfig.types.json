{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "stripInternal": true,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "exclude": ["src/**/*.stories.ts", "src/dev.ts", "src/Playground.vue"]
}
