{
  "name": "@prozorro/prozorro-ui",
  "private": false,
  "version": "0.1.0",
  "description": "Official Prozorro UI Library",
  "author": "Dmytro Rybachek",
  "license": "MIT",
  "main": "dist/prozorro-ui.cjs",
  "module": "dist/prozorro-ui.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/prozorro-ui.js",
      "require": "./dist/prozorro-ui.cjs"
    },
    "./dist/": {
      "import": "./dist"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && copyfiles ./package.json dist && npm run removeFromBuild:lib",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint:eslint && npm run lint:styles",
    "lint:eslint": "eslint .",
    "lint:styles": "stylelint \"src/**/*.{scss,vue}\"",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "vue-tsc --noEmit",
    "removeFromBuild:lib": "rimraf ./dist/robots.txt ./dist/test-data",
    "clean": "rimraf dist"
  },
  "keywords": [
    "typescript",
    "library",
    "prozorro",
    "UI"
  ],
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@storybook/vue3-vite": "^8.6.12",
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "copyfiles": "^2.4.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.92.1",
    "storybook": "^8.6.12",
    "stylelint": "^17.6.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.21",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.0.7"
  }
}
