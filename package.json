{
  "name": "@prozorro/prozorro-ui",
  "private": false,
  "version": "0.1.0",
  "description": "Official Prozorro UI Library",
  "author": "Dmytro Rybachek",
  "license": "MIT",
  "main": "dist/prozorro-ui.cjs",
  "module": "dist/prozorro-ui.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/prozorro-ui.js",
      "require": "./dist/prozorro-ui.cjs"
    },
    "./dist/": {
      "import": "./dist"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:types": "vue-tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --declarationDir dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "typescript",
    "library",
    "prozorro",
    "UI"
  ],
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@storybook/vue3-vite": "^8.6.12",
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "sass": "^1.92.1",
    "storybook": "^8.6.12",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.21",
    "vue-tsc": "^3.0.7"
  }
}
